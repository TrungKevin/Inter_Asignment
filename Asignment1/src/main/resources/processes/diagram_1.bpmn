      <bpmndi:BPMNShape id="Activity_UserClarify_di" bpmnElement="Activity_UserClarify">
        <dc:Bounds x="615" y="560" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_UserCounterResponse_di" bpmnElement="Activity_UserCounterResponse">
        <dc:Bounds x="630" y="110" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ProvisionAccess_di" bpmnElement="Activity_ProvisionAccess">
        <dc:Bounds x="990" y="510" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_HandleReject_di" bpmnElement="Activity_HandleReject">
        <dc:Bounds x="1050" y="80" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SendDecisionMail_di" bpmnElement="Activity_SendDecisionMail">
        <dc:Bounds x="1240" y="390" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1462v9g_di" bpmnElement="Event_1462v9g">
        <dc:Bounds x="1592" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1566" y="368" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SendCounterProposalMail_di" bpmnElement="Activity_SendCounterProposalMail">
        <dc:Bounds x="300" y="135" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CounterDecision_di" bpmnElement="Gateway_CounterDecision" isMarkerVisible="true">
        <dc:Bounds x="905" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="275" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_check_di" bpmnElement="Flow_start_to_check">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="230" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_check_to_admin_di" bpmnElement="Flow_check_to_admin">
        <di:waypoint x="330" y="400" />
        <di:waypoint x="390" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_admin_to_action_gateway_di" bpmnElement="Flow_admin_to_action_gateway">
        <di:waypoint x="500" y="400" />
