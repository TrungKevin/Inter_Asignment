      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_counter_mail_to_user_di" bpmnElement="Flow_counter_mail_to_user">
        <di:waypoint x="460" y="170" />
        <di:waypoint x="545" y="170" />
        <di:waypoint x="545" y="150" />
