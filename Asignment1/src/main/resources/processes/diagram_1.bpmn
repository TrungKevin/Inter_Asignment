      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_user_clarified_to_admin_di" bpmnElement="Flow_user_clarified_to_admin">
        <di:waypoint x="615" y="600" />
        <di:waypoint x="445" y="600" />
        <di:waypoint x="445" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="461" y="575" width="58" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_user_counter_to_gateway_di" bpmnElement="Flow_user_counter_to_gateway">
        <di:waypoint x="790" y="150" />
        <di:waypoint x="833" y="150" />
        <di:waypoint x="833" y="240" />
        <di:waypoint x="915" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_counter_accept_di" bpmnElement="Flow_counter_accept">
